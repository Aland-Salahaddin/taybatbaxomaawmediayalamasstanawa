{
  "rewrites": [
    { "source": "/((?!assets/|style\\.css|maintenance\\.html|api/).*)", "destination": "/maintenance.html" },
    { "source": "/analytics", "destination": "/404" },
    { "source": "/analytics.html", "destination": "/404" },
    { "source": "/api/analytics/(.*)", "destination": "/api/analytics.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Range" }
      ]
    }
  ]
}
