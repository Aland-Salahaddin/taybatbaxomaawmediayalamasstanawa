{
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/style.css", "destination": "/style.css" },
    { "source": "/maintenance.html", "destination": "/maintenance.html" },
    { "source": "/api/analytics/(.*)", "destination": "/api/analytics.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/analytics", "destination": "/404" },
    { "source": "/analytics.html", "destination": "/404" },
    { "source": "/(.*)", "destination": "/maintenance.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Range" }
      ]
    }
  ]
}
